<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- indicates that the server.cjs file is a node.js application to be handled by the iisnode module -->
    <handlers>
      <add name="iisnode" path="server.cjs" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- First, let IIS serve physical files directly if they exist in dist or root -->
        <rule name="StaticContent" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Route all other dynamic and API requests to server.cjs (Node.js/Express) -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.cjs" />
        </rule>
      </rules>
    </rewrite>

    <!-- CRITICAL: Pass Express custom JSON responses (like 401, 403, 500) directly to the client -->
    <!-- Without this, IIS intercepts non-200 responses and replaces them with HTML, breaking JSON parsing -->
    <httpErrors existingResponse="PassThrough" />

    <!-- iisnode configuration -->
    <!-- 
      คำแนะนำสำหรับการแก้ไขข้อผิดพลาด HRESULT: 0x2 (File Not Found):
      1. ตั้งค่า loggingEnabled="false" เพื่อปิดการบันทึก Log ไฟล์ ซึ่งช่วยข้ามปัญหาเรื่องสิทธิ์การเขียนไฟล์ (Write Permission) ใน IIS Application Pool/Plesk
      2. หากเซิร์ฟเวอร์ยังพบข้อผิดพลาด HRESULT: 0x2 แสดงว่า IIS หาตัวโปรแกรม node.exe ไม่พบ ให้คุณเปิดใช้งานและกำหนดเส้นทางใน attribute ได้ด้วยตนเองตรงส่วน iisnode ด้านล่างนี้:
         nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;" (หรือเส้นทาง node.exe บนเครื่อง Server ของคุณ)
         เช่น สำหรับ Plesk: nodeProcessCommandLine="&quot;C:\Program Files (x86)\Plesk\Additional\node\v20.x\node.exe&quot;"
    -->
    <iisnode 
      node_env="production"
      debuggingEnabled="false"
      loggingEnabled="false"
      devErrorsEnabled="false"
      watchedFiles="web.config;*.js;*.cjs;*.json"
    />
  </system.webServer>
</configuration>
